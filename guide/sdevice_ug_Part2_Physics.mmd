    Formula = 0
    1/kappa = 0.03 # [K cm/W]
    1/kappa_b = 1.5600e-03 # [cm/w]
    1/kappa_c = 1.6500e-06 # [cm/(W K)]
    kappa = 1.5 # [W/(K cm)]
    kappa_b = 0.0000e+00 # [W/(K^2 cm)]
    kappa_c = 0.0000e+00 # [W/(K^3 cm))]
}
