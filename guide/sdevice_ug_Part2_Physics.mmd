\begin{tabular}{lll}
\hline Material & \(\kappa[\mathrm{W} /(\mathrm{cm} \mathbf{K})]\) & Reference \\
\hline Silicon & Equation 1113 & {\([3]\)} \\
Ceramic & 0.167 & {\([4]\)} \\
\(\mathrm{SiO}_{2}\) & 0.014 & {\([1]\)} \\
Poly Si & 1.5 & \(\approx \mathrm{Si}\) \\
\hline
\end{tabular}
