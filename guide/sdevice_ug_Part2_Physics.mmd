        hBarrierTunneling(Nonlocal="NLM_silicon_oxide")
        TrapVolume=1e-6
        HuangRhys=70
        PhononEnergy=0.02
    #
        Degradation
        Conc=1e4 EnergyMid=0 Donor
        ActEnergy=2
