            [ Material | Region = "<name>" ] ) \{
    Traps (
        <trap_specifications>
        Degradation [(PowerLaw)]
        Conc \(=\left\langle N_{\text {it }}^{0}\right\rangle\)
        BondConc \(=\langle N\rangle\) [BondConcSFactor=["<dataset_name>" |
                "<pmi_model_name>"] ]
        ActEnergy \(=<\varepsilon_{\mathrm{A}}^{0}>\)
