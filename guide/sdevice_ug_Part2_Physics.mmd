        OpticalDevice = [ "tmm1" "tmm2" "tmm3" ]
    ) { ... }
    optdevice tmm1 () {Physics {Optics (Excitation (Wavelength=0.4) ) } }
    optdevice tmm2 () {Physics {Optics (Excitation (Theta=50) ) } }
```

