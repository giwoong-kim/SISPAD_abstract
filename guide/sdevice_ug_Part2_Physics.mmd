    Transition( ... CEModel("CEModel_Depassivation" 2))
            # Equation 618 for electrons
    Transition( ... CEModel("CEModel_Depassivation" 3))
            # Equation 618 for holes
    Transition( ... CEModel("CEModel_Depassivation" 4))
        # Equation 618 for electrons as per
        # Tyaginov hot-carrier degradation model
    Transition( ... CEModel("CEModel_Depassivation" 5))
        # Equation 618 for holes as per
```

