        [PowerEnhan \(=\left(\left\langle\beta_{0}\right\rangle\left\langle\beta_{/ /}\right\rangle\left\langle\beta_{\perp}\right\rangle\right)\) ]
        [CurrentEnhan \(=\left(<\delta_{\text {Tun }}><\rho_{\text {Tun }}><\delta_{\mathrm{HC}}><\rho_{\mathrm{HC}}>\right)\) ]
        [FowlerNordheimEnhan \(=\left(\left\langle\delta_{\mathrm{FN}}\right\rangle\left\langle\rho_{\mathrm{FN}}\right\rangle\right)\) ]
