\vec{S}_{n}=-\frac{5 r_{n}}{2}\left(\frac{k T_{n} \rightarrow}{q} J_{n}+f_{n}^{\mathrm{hf}} \hat{\kappa}_{n} \frac{\partial\left(w_{n} \Pi_{n}\right)}{\partial w_{n}} \nabla T_{n}\right)
