  *	gamma	 (4)= 1.790 ,	4.840	# [1]
  *	gamma	 (5)= 1.770 ,	4.680	# [1]
  *	gamma	 (6)= 1.750 ,	4.530	# [1]
  *	gamma	 (7)= 1.740 ,	4.350	# [1]
  *	gamma	 (8)= 1.730 ,	4.170	# [1]
  *	gamma	 (9)= 1.710 ,	3.970	# [1]
  *	gamma	 (10)= 1.700,	3.740	# [1]		#see GaAs

  *	theta	= 0.5 ,	0.5	# [1]
