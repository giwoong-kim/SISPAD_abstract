#! MODEL: Temperature and Doping dependent model from sdevice
#! MATERIAL: InGaAs
#! EXPRESSION: 
#! Temperature and doping dependent minority carrier lifetime is calculated using,
#! tau = taumin + ( taumax - taumin ) / ( 1 + ( N/Nref )^gamma)
#! where,
#! tau(T) = tau * ( (T/300)^Talpha )  
#! or
#! tau(T) = tau * exp( Tcoeff * ((T/300)-1) )
#! REFERENCE: 
#! Sentaurus Device User Guide 
Scharfetter
{ 
  * relation and trap level for SRH recombination:
  * tau = taumin + ( taumax - taumin ) / ( 1 + ( N/Nref )^gamma)
  * tau(T) = tau * ( (T/300)^Talpha )          (TempDep)
  * tau(T) = tau * exp( Tcoeff * ((T/300)-1) ) (ExpTempDep)
	taumin	= 0.0000e+00 ,	0.0000e+00	# [s]
	taumax	= 1e-9 ,	1e-9	# [s]
	Nref	= 1.0000e+16 ,	1.0000e+16	# [cm^(-3)]
	gamma	= 1 ,	1	# [1]
	Talpha	= 0.0000e+00 ,	0.0000e+00	# [1]
	Tcoeff	= 0.0000e+00 ,	0.0000e+00	# [1]
	Etrap	= 0.0000e+00	# [eV]
}

Auger
{
	Xmax (0) = 0.0
	Xmax (1) = 0.47
	Xmax (2) = 1.0

	A (0) = +2.2000000e-27, +2.2000000e-27 # [cm^6/s] # [Ioffe] # Data for holes taken from electrons
	A (1) = +7.0000000e-29, +7.0000000e-29 # [cm^6/s] # [Ioffe] # Data for holes taken from electrons
	A (2) = +1.0000000e-30, +1.0000000e-30 # [cm^6/s] # [Ioffe] # Data for holes taken from electrons
	B (0) = +0.0000000e+00, +0.0000000e+00 # [cm^6/s]
	B (1) = +0.0000000e+00, +0.0000000e+00 # [cm^6/s]
