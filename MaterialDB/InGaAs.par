	gamma_1(1)      = 6.85  # [1]
	gamma_2(0)      = 8.3   # [1]
	gamma_2(1)      = 2.1   # [1]
	gamma_3(0)      = 9.1   # [1]
	gamma_3(1)      = 2.9   # [1]
	so(0)   = 0.38  # [eV]
	so(1)   = 0.34  # [eV]
	ep_te(0)        = 21.5  # [eV]
	ep_te(1)        = 28.8  # [eV]
	ep_tm(0)        = 21.5  # [eV]
	ep_tm(1)        = 28.8  # [eV]
