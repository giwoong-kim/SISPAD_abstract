  *	B(1/kappa_b(1))	= 0.0000e+00	# [cm/W]
  *	C(1/kappa_b(1))	= 0.0000e+00	# [cm/W]

  *	* parameter 1/kappa_c:
  *	Xmax(0)	= 0.0000e+00	# [1]
  *	1/kappa_c(0)	= 0.0000e+00	# [cm/(W K)]
  *	Xmax(1)	= 1	# [1]
