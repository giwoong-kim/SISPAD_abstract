vanOverstraetendeMan * Impact Ionization:
{ * G_impact = alpha_n n v_drift_n  +  alpha_p p v_drift_p
  * with alpha = gamma a  exp(-b gamma/E) for E<E0 (low) and E>E0 (high)
  *  with gamma = tanh(hbarOmega/(2kT0)) / tanh(hbarOmega/(2kT))

	Xmax (0) = 0.0
	Xmax (1) = 0.47
	Xmax (2) = 1.0

	a(low) (0)	= 3.3687e+05 ,	8.7961e+05	# [1/cm] # converted from [Ioffe]  
	a(low) (1)	= 3.2568e+05 ,	6.3968e+05	# [1/cm] # fitted values from [85Osa]
	a(low) (2)	= 2.0000e+08 ,	3.0000e+06	# [1/cm] # fitted values from [78Pea] with (100) orientation
	a(high) (0)	= 3.3687e+05 ,	8.4218e+06	# [1/cm] # hole value from [Ioffe] 
	a(high) (1)	= 3.2568e+05 ,	6.3968e+05	# [1/cm]
	a(high) (2)	= 2.0000e+08 ,	3.0000e+06	# [1/cm]
	b(low) (0)	= 2.9944e+05 ,	1.5908e+05	# [V/cm] # converted from [Ioffe]  
	b(low) (1)	= 1.2080e+06 ,	1.5430e+06	# [V/cm] # fitted values from [85Osa]
	b(low) (2)	= 3.8360e+06 ,	2.1440e+06	# [V/cm] # fitted values from [78Pea] with (100) orientation
	b(high) (0)	= 2.9944e+05 ,	2.8821e+05	# [V/cm] # hole value from [Ioffe] 
	b(high) (1)	= 1.2080e+06 ,	1.5430e+06	# [V/cm]
	b(high) (2)	= 3.8360e+06 ,	2.1440e+06	# [V/cm]
	E0 (0)	= 3.0000e+04 ,	3.0000e+04	# [V/cm] # [Ioffe] 
	E0 (1)	= 3.0000e+04 ,	3.0000e+04	# [V/cm]
	E0 (2)	= 3.0000e+04 ,	3.0000e+04	# [V/cm]
	hbarOmega (0)	= 0.03 ,	0.03	# [eV] # [Ioffe] 
	hbarOmega (1)	= 0.034 ,	0.034	# [eV] # [Ioffe] 
	hbarOmega (2)	= 0.035 ,	0.035	# [eV] # [Ioffe] 
}

#! MODEL: Room temperature Radiative Recombination model parameters from Levinshtein
#! MATERIAL: InGaAs
#! VALIDITY: This model is valid only for T=300K and doping concentration of 1e18 cm^-3
#! REFERENCE: 
#! "Handbook series on Semiconductor Parameters, Vol II"
#! M. Levenshtein, S. Rumyantsev, M. Shur, World Scientific, 1999
#RadiativeRecombination
#{
#	C = +1.0000000e-8
#}

RadiativeRecombination
{
	Xmax (0) = 0.0
	Xmax (1) = 0.47
	Xmax (2) = 1.0

	C (0) = +1.1000000e-10 # [Ioffe] 
	C (1) = +9.6000000e-11 # [Ioffe] 
	C (2) = +7.2000000e-10 # [Ioffe] 
}

