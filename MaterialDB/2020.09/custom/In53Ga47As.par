#! MODEL: Temperature and Doping dependent model from sdevice
#! MATERIAL: InGaAs
#! EXPRESSION: 
#! Temperature and doping dependent minority carrier lifetime is calculated using,
#! tau = taumin + ( taumax - taumin ) / ( 1 + ( N/Nref )^gamma)
#! where,
#! tau(T) = tau * ( (T/300)^Talpha )  
#! or
#! tau(T) = tau * exp( Tcoeff * ((T/300)-1) )
#! REFERENCE: 
#! Sentaurus Device User Guide 
Scharfetter
{ 
  * relation and trap level for SRH recombination:
  * tau = taumin + ( taumax - taumin ) / ( 1 + ( N/Nref )^gamma)
  * tau(T) = tau * ( (T/300)^Talpha )          (TempDep)
  * tau(T) = tau * exp( Tcoeff * ((T/300)-1) ) (ExpTempDep)
	taumin	= 0.0000e+00 ,	0.0000e+00	# [s]
	taumax	= 1e-9 ,	1e-9	# [s]
	Nref	= 1.0000e+16 ,	1.0000e+16	# [cm^(-3)]
	gamma	= 1 ,	1	# [1]
	Talpha	= 0.0000e+00 ,	0.0000e+00	# [1]
	Tcoeff	= 0.0000e+00 ,	0.0000e+00	# [1]
	Etrap	= 0.0000e+00	# [eV]
}

Auger
{
	A	= +7.0000000e-29, +7.0000000e-29 # [cm^6/s] # [Ioffe] # Data for holes taken from electrons
	B	= +0.0000000e+00, +0.0000000e+00 # [cm^6/s]
	C	= +0.0000000e+00, +0.0000000e+00 # [cm^6/s]
	H	= +0.0000000e+00, +0.0000000e+00 # [1]
	N0	= +1.0000000e+18, +1.0000000e+18 # [cm^-3]
}

vanOverstraetendeMan * Impact Ionization:
{ * G_impact = alpha_n n v_drift_n  +  alpha_p p v_drift_p
  * with alpha = gamma a  exp(-b gamma/E) for E<E0 (low) and E>E0 (high)
  *  with gamma = tanh(hbarOmega/(2kT0)) / tanh(hbarOmega/(2kT))

	a(low)	= 3.2568e+05 ,	6.3968e+05	# [1/cm] # fitted values from [85Osa]
	a(high)	= 3.2568e+05 ,	6.3968e+05	# [1/cm]
	b(low)	= 1.2080e+06 ,	1.5430e+06	# [V/cm] # fitted values from [85Osa]
	b(high)	= 1.2080e+06 ,	1.5430e+06	# [V/cm]
	E0		= 3.0000e+04 ,	3.0000e+04	# [V/cm]
	hbarOmega	= 0.034 ,	0.034	# [eV] # [Ioffe] 
}

RadiativeRecombination
{
	C	= +9.6000000e-11 # [Ioffe] 
}

