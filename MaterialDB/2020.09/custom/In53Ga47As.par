ConstantMobility
{ 
  * mu_const = mumax (T/T0)^(-Exponent)
	mumax		= 1.4000e+04 ,	320	# [cm^2/(Vs)] #[00Sot]
	Exponent	= 1.59 ,	1.59	# [1] #[00Sot]
}

DopingDependence
{
  * For doping dependent mobility model three formulas
  * can be used. Formula1 is based on Masetti et al. approximation.
  * Formula2 uses approximation, suggested by Arora.
	formula	= 2 ,	2	# [1]
  * If formula=2, model suggested by Arora is used:
  * mu_dop = muminA + mudA/(1.+(N/N00)^AA),
  * where muminA=Ar_mumin*(T/T0)^Ar_alm; mudA = Ar_mud*(T/T0)^Ar_ald
  * N is net doping
  * N00=Ar_N0*(T/T0)^Ar_alN; AA = Ar_a*(T/T0)^Ar_ala

	Ar_mumin 	= 3.0000e+02 ,	1.0000e+01	# [cm^2/Vs] #[00Sot]
	Ar_alm   	= 0.0000e+00 ,	0.0000e+00 # [1] #[00Sot]
	Ar_mud   	= 1.3700e+04 ,	3.1000e+02	# [cm^2/Vs] #[00Sot]
	Ar_ald   	= -1.612e+00 ,	-1.623e+00	# [1] #[00Sot]
	Ar_N0    	= 1.3000e+17 ,	4.9000e+17	# [cm^(-3)] #[00Sot]
	Ar_alN   	= 3.6800e+00 ,	3.0000e+00	# [1] #[00Sot]
	Ar_a     	= 4.8000e-01 ,	4.03000e-01	# [1] #[00Sot]
	Ar_ala   	= 0.0000e+00 ,	0.0000e+00	# [1] #[00Sot]
}
 
