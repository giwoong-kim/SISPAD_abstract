Epsilon
  {
    * Ratio of the permittivities of material and vacuum
    * epsilon() = epsilon

    epsilon = 10.0 #[1], [Hig16]
    * epsilon = 10.05 #[1], [Pee10], 9.9-10.2
    * epsilon = 13.6 #[1], [Lee06]
  }

Epsilon_Inf
  {
    * Ratio of the high frequency limit of permittivities of material and vacuum
    * perp. to c-axis
    epsilon_inf = 10.0 #[1], set to low frequency value
  }

Epsilon_aniso
  {
    * Ratio of the permittivities of material and vacuum
    * epsilon() = epsilon

    epsilon = 10.0 #[1], set to iso value
  }

* Epsilon_Inf_aniso
*   {
*     * Ratio of the permittivities of material and vacuum
*     * parallel to c-axis
* 
*     epsilon_inf = 10.0 #[1], set to low frequency value
*   }

* refractiveindex{...}
* By default, for mole fraction dependency of parameters
* of the model, the following linear interpolation is applied
* between two materials: P = x * P(AlN) + (1-x) * P(GaN)
* where P(m) is a parameter of material m.
* If the parameters are specified, then its values
* will be used instead of the interpolation.

* ComplexRefractiveIndex { ... } 
* By default, for mole fraction dependency of parameters
* of the model, the following linear interpolation is applied
* between two materials: P = x * P(AlN) + (1-x) * P(GaN)
* where P(m) is a parameter of material m.
* If the parameters are specified, then its values
* will be used instead of the interpolation.

SpectralConversion
  { 
    * Spectral Conversion Model
    * No default model, user has to define.
    * All wavelength parameters should be in nanometers.
    * Choice of Analytic or NumericalTable selected in Physics section of region
    *
    * ConversionEfficiency = float     * ratio of absorbed photons that are reemitted.
    * AbsorptionScaling = float        * scale absorption
    * EmissionScaling = float          * scale emission
    * Analytic (
    *   AbsorptionProfile = (
    *      Gaussian(lambda0 sigma peakvalue dc_offset lambda_range0 lambda_range1)
    *      Lorentzian(lambda0 width peakvalue dc_offset lambda_range0 lambda_range1)
    *      ...
    *   )
    *   EmissionProfile = (
    *      Gaussian(lambda0 sigma peakvalue dc_offset lambda_range0 lambda_range1)
    *      Lorentzian(lambda0 width peakvalue dc_offset lambda_range0 lambda_range1)
    *      ...
    *   )
    * )
    * NumericalTable (
    *   AbsorptionProfile = (
    *      lambda0 value0
    *      lambda1 value1
    *      ...
    *   )
    *   EmissionProfile = (
    *      lambda0 value0
    *      lambda1 value1
    *      ...
    *   )

    ConversionEfficiency = 1.0
  }

LatticeHeatCapacity
  {
    * cv() = cv + cv_b * T + cv_c * T^2 + cv_d * T^3 
    * lumped electron-hole-lattice heat capacity
    * Specific heat 0.56 Jg-1K-1 or 0.49 Jg-1K-1 [Ste15]
    * Density 5.95 g/cm3 [85,87,139]
    * cv = specific heat * density = 5.95 * 0.56 J/K cm3
    cv = 3.332 #[J/(K cm^3)], [Ste15] 
    cv_b = 0.0000e+00 #[J/(K^2 cm^3)]
    cv_c = 0.0000e+00 #[J/(K^3 cm^3)]
    cv_d = 0.0000e+00 #[J/(K^4 cm^3)]
  }

Kappa
  { 
    * Lattice thermal conductivity
    * Formula = 0:
    * thermal resistivity = 1 / ( 1/kappa + 1/kappa_b * T + 1/kappa_c * T^2 )
    * Formula = 1:
    * thermal conductivity = kappa + kappa_b * T + kappa_c * T^2

    Formula = 1
    kappa = 0.11 #[W/cm K], [100] direction [Hig16], [Guo14]
    * kappa = 0.11 #[W/cm K], [100] direction [Hig16]    
    * kappa = 0.147 #[W/cm K], [001] direction [Guo14]
    * kappa = 0.133 #[W/cm K], [-201] direction [Guo14]
    * kappa = 0.27 #[W/cm K], [010] direction [Guo14], [Hig16]
    kappa_b = 0.0
    kappa_c = 0.0
  }

Kappa_aniso
  { 
    * Lattice thermal conductivity
    * Formula = 0:
    * thermal resistivity = 1 / ( 1/kappa + 1/kappa_b * T + 1/kappa_c * T^2 )
    * Formula = 1:
    * thermal conductivity = kappa + kappa_b * T + kappa_c * T^2

    Formula = 1
    kappa = 0.11 #[W/cm K], [100] direction [Hig16], [Guo14]
    * kappa = 0.11 #[W/cm K], [100] direction [Hig16]    
    * kappa = 0.147 #[W/cm K], [001] direction [Guo14]
    * kappa = 0.133 #[W/cm K], [-201] direction [Guo14]
    * kappa = 0.27 #[W/cm K], [010] direction [Guo14], [Hig16]
    kappa_b = 0.0
    kappa_c = 0.0
  }

