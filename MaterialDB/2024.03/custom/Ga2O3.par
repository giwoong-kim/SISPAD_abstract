    E_As_0 = 0.052 #[eV], [20Won]
    alpha_As = 3.398e-8 #[20Won]
    g_As = 2 #[1]
    Xsec_As = 1.0000e-12 #[cm^2]

    E_NDopant_0	= 0.06 #[eV], [16Hig], for Sn Range 60meV to 80meV
    g_NDopant = 2 #no reference
  }


