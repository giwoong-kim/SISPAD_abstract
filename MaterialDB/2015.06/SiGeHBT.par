	C(epsilon(2))	= 0.0000e+00	# [eV]
	Xmax(3)	= 0.3	# [1]
	epsilon(3)	= 12.99	# [eV]
	B(epsilon(3))	= 0.0000e+00	# [eV]
	C(epsilon(3))	= 0.0000e+00	# [eV]
	Xmax(4)	= 0.4	# [1]
	epsilon(4)	= 13.42	# [eV]
	B(epsilon(4))	= 0.0000e+00	# [eV]
	C(epsilon(4))	= 0.0000e+00	# [eV]
	Xmax(5)	= 1.0	# [1]
	epsilon(5)	= 13.42	# [eV]
	B(epsilon(5))	= 0.0000e+00	# [eV]
	C(epsilon(5))	= 0.0000e+00	# [eV]
}

