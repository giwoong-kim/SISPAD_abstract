        beta    = 0.00e+00    # [K]
        Tpar    = 300.0000e+00    # [K]
        Eg0     = 1.16       # [eV]
        alpha   = 0.00e+00    # [eV K^-1]
        beta = 0.0000e+00    # [K]
        Chi0    = 4.05  # [eV]
}

OldSlotboom
{ * deltaEg = dEg0 + Ebgn ( ln(N/Nref) + [ (ln(N/Nref))2 + 0.5]^1/2 )
  * dEg0 is defined in BandGap section
        Ebgn    = 9.0000e-03    # [eV]
        Nref    = 1.0000e+17    # [cm^(-3)]
}

Slotboom
{ * deltaEg = dEg0 + Ebgn ( ln(N/Nref) + [ (ln(N/Nref))2 + 0.5]^1/2 )
  * dEg0 is defined in BandGap section
        Ebgn    = 6.9200e-03    # [eV]
        Nref    = 1.3000e+17    # [cm^(-3)]
}

delAlamo
{ * deltaEg = dEg0 + Ebgn  ln(N/Nref)
  * dEg0 is defined in BandGap section
        Ebgn    = 0.0187        # [eV]
        Nref    = 7.0000e+17    # [cm^(-3)]
}

Bennett
{ * deltaEg = dEg0 + Ebgn (ln(N/Nref))2
  * dEg0 is defined in BandGap section
        Ebgn    = 6.8400e-03    # [eV]
        Nref    = 3.1620e+18    # [cm^(-3)]
}

eDOSMass
{
        Formula = 2     # [1]
        Nc300   = 3.0000e+19    # [cm-3]
}

hDOSMass
{
        Formula = 2     # [1]
        Nv300   = 2.1000e+19    # [cm-3]
}

SchroedingerParameters:
{ * Lifting of degeneracy of bulk valleys. The value for
  * electrons is added to the band edge for the subband ladder
  * of lower degeneracy if positive, and subtracted from the
  * band edge for the ladder of higher degeneracy if negative.
  * For holes, the value is added to the band edge for the
  * heavy hole band is positive, subtracted from that of the
  * light hole band if negative.  The signs are such that the
  * shift always moves the band edges 'outward', away from
  * midgap.  The gap itself is defined as the separation of
  * the unshifted band edges and remains unaffected.
        formula = 1, 1  
        offset  = 0.0 , 0.0     # [eV] 
        A       = 4.31  # [1]   
        B       = 0.69        # [1]  
        C       = 4.80        # [1]
} 

QuantumPotentialParameters
{ * gamma:  weighting factor for quantum potential
  * theta:  weight for quadratic term
  * xi:     weight for quasi Fermi potential
  * eta:    weight for electrostatic potential
        gamma   = 3.6 , 5.6     # [1]
        theta   = 0.5 , 0.5     # [1]
        xi      = 1 ,   1       # [1]
        eta     = 1 ,   1       # [1]
} 

ConstantMobility:
{ * mu_const = mumax (T/T0)^(-Exponent)
        * mumax        = 1445., 486.   # [cm2/(Vs)]
	  mumax        = 40   , 4      # [cm2/(Vs)]
        Exponent     = 1.0 , 1.0
}

DopingDependence:
{
        formula = 1 ,   1       # [1]
  * If formula=1, model suggested by Masetti et al. is used:
  * mu_dop = mumin1 exp(-Pc/N) + (mu_const - mumin2)/(1+(N/Cr)^alpha)
  *                             - mu1/(1+(Cs/N)^beta)
  * with mu_const from ConstantMobility
*        mumin1  = 56.0 ,        46.0    # [cm2/Vs]
*        mumin2  = 56.0 ,        0.0000e+00    # [cm2/Vs]
        mumin1  = 20.0 ,        2.0    # [cm2/Vs]
        mumin2  = 20.0 ,        0.0000e+00    # [cm2/Vs]
        mu1  = 43.4 ,        29    # [cm2/Vs]
        Pc  = 0.0000e+00 ,        9.2300e+16    # [cm2/Vs]
        Cr  = 9.6800e+16 ,        2.2300e+17    # [cm2/Vs]
        Cs  = 3.4300e+20 ,        6.1000e+20    # [cm2/Vs]
        alpha  = 0.68 ,        0.719    # [cm2/Vs]
        beta  = 2 ,        2    # [cm2/Vs]
}

PhuMob:
{ * Philips Unified Mobility Model:
         *mumax_As = 1445.   # [cm2/(Vs)]
	mumax_As = 40.   # [cm2/(Vs)]
*        mumin_As = 56.0     # [cm2/Vs]
        mumin_As = 20.0     # [cm2/Vs]
        theta_As = 2.285 # [1]
        n_ref_As = 9.6800e+16    # [cm^(-3)]
        alpha_As = 0.68  # [1]
        * mumax_P = 1445.   # [cm2/(Vs)]
	mumax_P = 40.   # [cm2/(Vs)]
*        mumin_P = 56.0     # [cm2/Vs]
        mumin_P = 20.0     # [cm2/Vs]
        theta_P = 2.285 # [1]
        n_ref_P = 9.6800e+16    # [cm^(-3)]
        alpha_P = 0.68  # [1]
        * mumax_B = 486.   # [cm2/(Vs)]
	mumax_B = 4.   # [cm2/(Vs)]
*        mumin_B = 46.0     # [cm2/Vs]
        mumin_B = 2.0     # [cm2/Vs]
        theta_B = 2.247 # [1]
        n_ref_B = 2.2300e+17    # [cm^(-3)]
        alpha_B = 0.719 # [1]
        nref_D = 4.0000e+20    # [cm^(-3)]
        nref_A = 7.2000e+20    # [cm^(-3)]
        cref_D = 0.21  # [1]
        cref_A = 0.5   # [1]
        me_over_m0 = 1     # [1]
        mh_over_m0 = 1.258 # [1]
        f_CW = 2.459 # [1]
        f_BH = 3.828 # [1]
}

ENormalMob
{ * mu_Enorm^(-1) = mu_ac^(-1) + mu_sr^(-1)  with:
  * mu_ac = B / Enorm + C (T/T0)^(-1) (N/N0)^lambda / Enorm^(1/3) )
  * mu_sr^-1 = Enorm^(A+alpha*n/N^nu) / delta + Enorm3 / eta
  * EnormalDependence is added with factor exp(-l/l_crit), where l is
  * the distance to the nearest point of DES_c_Si/DES_c_SiO2 interface. Factor is
  * equal to 1 if l_crit > 100.
        B = 3.6100e+07 ,  1.5100e+07      # [cm/s]
        C = 1.7000e+04 ,  4.1800e+03      # [cm5/3/(sV2/3)]
        N0 = 1 ,   1       # [cm^(-3)]
        lambda = 0.0233 ,       0.0119  # [1]
        k = 1 ,   1       # [1]
        delta = 3.5800e+18 ,  4.1000e+15      # [V/s]
        A = 2.58 ,   2.18       # [1]
        alpha = 6.8500e-21 ,  7.8200e-21      # [1]
        N1 = 1 ,   1       # [cm^(-3)]
        nu = 0.0767 ,   0.123       # [1]
        eta = 1.0e+300 ,  1.0e+300      # [V2/cm*s]
        l_crit = 1.0000e-06 ,  1.0000e-06      # [cm]
}    

HighFieldDependence:
{ * Caughey-Thomas model:
  * mu_highfield = mu_lowfield / ( 1 + (mu_lowfield E / vsat)^beta )1/beta
  * beta = beta0 (T/T0)^betaexp.

 * For vsat either Formula1 or Formula2 can be used.
        Vsat_Formula    = 1 ,   1       # [1]
 * Formula1 for saturation velocity:
 *            vsat = vsat0 (T/T0)^(-Vsatexp)
 * (Parameter Vsat_Formula has to be not equal to 2)
        beta0  = 1.20 ,        0.93    # [cm2/Vs]
        betaexp  = 1.0 ,        1.0    # [cm2/Vs]
        vsat0  = 1.0100e+07 ,        1.0100e+07    # [cm2/Vs]
        vsatexp  = 1.0 ,        1.0    # [cm2/Vs]
}

}

MaterialInterface="PolySi/SiliconGermanium" {

SurfaceRecombination * surface SRH recombination:
{ * s = S0 ( 1 + Sref ( N/Nref )^gamma ) recombination velocity
	S0	= 1 ,	1	# [cm/s]
	Nref	= 1.0000e+22		        # [cm^(-3)]
	Etrap	= 0.0000e+00	# [eV]
}

}

MaterialInterface="Oxide/SiliconGermanium" {

SurfaceRecombination * surface SRH recombination:
{ * s = S0 ( 1 + Sref ( N/Nref )^gamma ) recombination velocity
	S0	= 1 ,	1	# [cm/s]
	Nref	= 1.0000e+22 		        # [cm^(-3)]
	Etrap	= 0.0000e+00	# [eV]
}

}




