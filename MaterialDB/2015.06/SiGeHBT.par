        B(mumin1(3))     = 0. , 0. 
        C(mumin1(3))     = 0. , 0. 
        Xmax(4) = 0.4, 0.4
        mumin1(4)  = 140.0 ,        69.0    # [cm2/Vs]
        B(mumin1(4))     = 0. , 0. 
        C(mumin1(4))     = 0. , 0. 
        Xmax(5) = 1.0, 1.0
        mumin1(5)  = 140.0 ,        69.0    # [cm2/Vs]
        B(mumin1(5))     = 0. , 0. 
        C(mumin1(5))     = 0. , 0. 

       * parameter mumin2:
