	eValley"X3"(1)(ml=1.0532 mt=0.1888 energy=0.303979 alpha=0.5 degeneracy=1 xiu=5.236 xid=1.4028)
	hValley"LH"(1)(m=0.09600850 energy=0.0 alpha=0.0 degeneracy=1)
