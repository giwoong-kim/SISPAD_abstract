	eValley"X3"(0,0,1)(ml=1.2099 mt=0.1929 energy=0.53335 alpha=0.5 degeneracy=1 xiu=5.016 xid=1.3362)
	hValley"LH"(m=0.04987289 energy=0.0 alpha=0.0 degeneracy=1)
	hValley"HH"(m=0.56322414 energy=0.0 alpha=0.0 degeneracy=1)

	eValley"Gamma"(1)(m=0.072 energy=0.0 alpha=1.0 degeneracy=1 xid=-8.0112)
	eValley"L1"(1)(ml=0.9664 mt=0.098 energy=0.2376703 alpha=0.5 degeneracy=1 xiu=14.5 xid=-3.056)
	eValley"L2"(1)(ml=0.9664 mt=0.098 energy=0.2376703 alpha=0.5 degeneracy=1 xiu=14.5 xid=-3.056)
	eValley"L3"(1)(ml=0.9664 mt=0.098 energy=0.2376703 alpha=0.5 degeneracy=1 xiu=14.5 xid=-3.056)
