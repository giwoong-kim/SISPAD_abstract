	eValley"Gamma"(m=0.04421 energy=0.0 alpha=1.0 degeneracy=1 xid=-10.576)
	eValley"L1"(1,1,1)(ml=1.2322 mt=0.061938 energy=0.54908892 alpha=0.5 degeneracy=1 xiu=14.5 xid=-2)
	eValley"L2"(-1,1,1)(ml=1.2322 mt=0.061938 energy=0.54908892 alpha=0.5 degeneracy=1 xiu=14.5 xid=-2)
