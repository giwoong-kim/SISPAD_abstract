eDOSMass
	{						#4H-SiC
		Formula		=	1		#In sdevice, med/m0= [(6*mt)^2 * ml]^(1/3) + mm, mt = a * [Eg(0)/Eg(T)]
		a		=	10.2429		#med/m0= Mc^(2/3) * me, Mc=3 for 4H-SiC,
		ml		=	10.2429		#Nc(T)=2*(2pi*kb/h_Plank^2*med*T)^(3/2)= 2.5094e19 * {(med/m0)*(T/300)}^(3/2)
		mm		=	-33.049		#the values of a, ml, and mm correspond to me(DOS effective mass of electron)/m0 = 0.401
		Nc300		=	1.9150e19	#at T=300K [97Wel] and adjust the tempearture dependence between 300K and 1000K in [97Wel].


		#Formula	=	2		#4H-SiC,
		#Nc300		=	1.7193E+19	#me(DOS effective mass of electron)/m0 = 0.367 [96Per], 0.390 [96Vol], 0.394 [97Wel]
							#at T=0K. Using the ratio between T=0K and T=300K in [97Wel], med/m0 = 0.777, 0.826,
							#0.835 at T=300K. Correpondig Nc300 = 1.7193e19, 1.8828e19, 1.9150e19

	}

