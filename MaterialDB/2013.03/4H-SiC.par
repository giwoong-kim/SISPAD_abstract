Epsilon
	{
							#perp. to c-axis
		epsilon		=	9.66		#[70Pat], ioffe database,  6H-SiC
		#epsilon	=	9.76		#[94Nin, 05Pen], 6H-SiC+4H-SiC

	}
Epsilon_aniso
	{
							#parallel to c-axis
		epsilon		=	10.03		#ioffe database, [70Pat], ratio of 1.04
		#epsilon	=	9.98		#[94Nin], 6H-SiC
		#epsilon	=	10.32		#[05Pen], 4H-SiC
		#epsilon	=	10.1		#[06Zha], 4H-SiC
	}

