			NegInterfaceChargeMobility:
				 {
					E0			=	1.0e-6, 1.0e-6
					mu1			=	250.0,	250.0
					c_exp			=	0.5,	0.5
					l_crit			=	7.7e-8, 7.7e-8
				 }

			PosInterfaceChargeMobility:
				 {
					E0			=	1.0e-6, 1.0e-6
