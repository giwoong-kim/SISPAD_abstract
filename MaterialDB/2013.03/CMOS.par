				wt01		= 3.5e-07,	3.0e-7
				wt02		= 3.0e-06,	1.0e-5
				muac01		= 85.0,		1300.0
				muac02		= 300.0,	100.0
				mutf0		= 0.000069,	0.0051
				musp0		= 2.8e-3,	5.0e-5
				tsp0		= 2.7e-04,	1.5e-04
				ftf0		= 6.25e+03,	6.25e+03
				tmin		= 2.00e-03,	2.00e-03
				eta1		= 9.5,		7.5
				eta2		= 1.5,		1.5
				mutfh0		= 1.0e+06,	5.1
				ftfh0		= 1.0e+100,	6.25e+04
			}

		#for <110> channel, has to be deactivated in case of <100> channel
		IALMob "110":
			{
				EnormMinimum	=	0
				mumax_e		=	1417.0
