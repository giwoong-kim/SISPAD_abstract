#This parameter file is designed for simulation of MISFET-like devices with Si or SiGe channel material.
#It is the first version of a pre-calibrated parameter file for Si and SiGe.
#The parameter set represents an intial parameter set. Mostly fine-tuning and additional calibration
#is necessary.
#For cases where the channel orientation matters several parameter sets for the different channel
#orientations are given where only one set is activated and the other sets are commented out.

#[81Sze] Simon M. Sze, Kwok K. Ng, Physics of Semiconductor Devices, John Wiley & Sons, 2006
#[00Arx] Martin von Arx, Oliver Paul, Henry Baltes, Process-Dependent Thin-Film Thermal Conductivities
#for Thermal CMOS MEMS, Journal of Microelectromechanical Systems, Vol. 9, No. 1, 2000
#[90Mas] C. H. Mastrangelo, Y. C. Tai, R. S. Muller, Thermophysical properties of low-residual stress,
#silicon-rich, LPCVD siliconnitride films, Sens. Actuators, Vol. A23, 1990  
#[01Bou] V. Bougrov, M. E. Levinshtein, S. L. Rumyantsev, A. Zubrilov, Properties of Advanced
#Semiconductor Materials GaN, AlN, InN, BN, SiC, SiGe, John Wiley & Sons, New York, 2001 
#[73Bar] A. S. Barker, M. Ilegems, Infrared lattice vibrations and free-electron dispersion in GaN, 
#Phys. Rev., B7, 1973
#[77SiC] E. K. Sichel, J. I. Pankove, Thermal conductivity of GaN 25-360K, Phys. Chem. Solids, 39, 3, 1977
#[01Vur] I. Vurgaftman, J. R. Meyer, L. R. Ram-Mohan, Band parameters for III-V compound semiconductors
#and their alloys, Journal of Applied Physics, 89, 11, 2001
#[03Vur] I. Vurgaftman, L. R. Ram-Mohan, Band parameters for III-V compound semiconductors
#and their alloys, Journal of Applied Physics, 94, 6, 2003
#[01Gol] Y. Goldberg, Properties of Advanced
#Semiconductor Materials GaN, AlN, InN, BN, SiC, SiGe, John Wiley & Sons, New York, 2001, 31-47
#[97Mal] F. Malengreau, M. Vermeersch, S. Hagege, R. Sporken, M. D. Lange, R. Caudano, 
#J. Mater. Res., 12, 175, 1997
#[87Sla] G. A. Slack, R. A. Tanzilli, R. O. Pohl, J. W. Vandersande, J. Phys. Chem. Solids. 48, 7, 1987 
#[02Bul] C. Bulutay, Electron initiated impact ionization in AlGaN alloys, Semicond. Sci. Technol.,
#vol. 17, ppL59-L62
#[97[Wal] D. Walker et. al., Applied Physics Letters, vol. 70, no. 8, pp. 949-951, 1997
#[01Sch] Schaffler, Properties of Advanced Semiconductor Materials GaN, AlN, InN, BN, SiC, Sige,
#John Wiley & Sons, Inc., New York, pp. 149-188, 2001
#[64Gla] Glasbrenner and Slack, Phys. Rev., 164, 4A, pp 1058-1069, 1964
#[54STo] Stohr and Klemm, Anorg. Allgem. Chem., 241, pp. 305, 1954
#[58BRA] Braunstein, Moore, and Herman in C. Penn, T. Frommherz, and G. Bauer, Properties 
#of Silicon Germanium and SiGe: Carbon EMIS Datareviews Series, no. 24, chapter 4.1
#[81Jac] C. Jacoboni et al, Phys. Rev., B24, 2, pp. 1014, 1981
#[10Ene] Eneman, IEEE TED, vol. 57, no. 10, 2010
#[09Ton] H. Tong et al, Proc. of SPIE, vol. 7211, pp. 721103-1
#[00Pal] 

Material = "Oxide"
	{
		Epsilon
			{
				epsilon		=	3.9		#[81Sze]
			}
		Kappa
			{
				Formula		=	1
				kappa		=	0.007205	#[00Arx], averaged value from different materials and experiments
				kappa_b		=	1.265e-5	#[00Arx], averaged value from different materials and experiments
				kappa_c		=	0.0
			}
	}

Material = "Nitride"
	{
		Epsilon
			{
				epsilon		=	7.5		#consensus value (pure Si3N4), large spreading from 5 to 8 depending on stoichiometry (SiN, Si3N4)
			}
		Kappa
			{
				Formula		=	1
				kappa		=	0.032		#[90Mas], LPCVD nitride, value can drop down to 0.014 when having other deposition processes
				kappa_b		=	0.0
				kappa_c		=	0.0
			}
	}

Material = "InterfacialOxide"
	{
		Epsilon
			{
				epsilon		=	5.0		#internal calibration experience
			}

		Kappa
			{
				Formula		=	1
				kappa		=	0.007205	#values for pure SiO2
				kappa_b		=	1.265e-5	#values for pure SiO2
				kappa_c		=	0.0
			}
	}

Material = "HfO2"
	{
		Epsilon
			{
				epsilon		=	22.0		#consenus value, large spreading from 16 to 26
									#because of process dependent material properties
									#(crystalline, poly crystalline, amorphous) and
									#nitridation, lower values if nitrided (HfON, HfSiON)
			}

		Kappa
			{
				Formula		=	1
				kappa		=	0.023
				kappa_b		=	0.0
				kappa_c		=	0.0
			}
	}

Material = "Silicon"
	{
		Epsilon
			{
				epsilon		=	11.7			#ioffe database
			}

		Kappa
			{
				Formula		=	0

				1/kappa		=	-0.0393			#ioffe database, Glassbrenner and Slack 1964, extracted for 200-1000K
				1/kappa_b	=	1.5000e-03		#ioffe database, Glassbrenner and Slack 1964, extracted for 200-1000K
				1/kappa_c	=	1.8200e-06		#ioffe database, Glassbrenner and Slack 1964, extracted for 200-1000K

				#1/kappa	=	0.03
				#1/kappa_b	=	1.5600e-03
				#1/kappa_c	=	1.6500e-06
			}

		Bandgap
			{
				#currently no temperature dependence included
				Bgn2Chi		=	0.5
				dEg0(Bennett)	=	0.0000e+00
				dEg0(Slotboom)	=	0.0000e+00
				dEg0(OldSlotboom)=	0.0000e+00
				dEg0(delAlamo)	=	0.0000e+00
				beta		=	0.0000e+00
				Eg0		=	1.12
				alpha		=	0.0000e+00
				beta		=	0.0000e+00
				Chi0		=	4.05
				Tpar		=	3.0e+02
			}

		Slotboom
			{
				Ebgn		=	6.9200e-03
				Nref		=	1.3000e+17
			}

		eDOSMass
			{
				Formula		=	2
				Nc300		=	2.89e+19
			}

		hDOSMass
			{
				Formula		=	2
				Nv300		=	1.819e+19
			}

		QuantumPotentialParameters "100"
			{
				gamma		=	4.3,	8.3
			}

		QuantumPotentialParameters "110"
			{
				gamma		=	6.0,	3.3
			}

		QuantumPotentialParameters "111"
			{
				gamma		=	6.0,	3.3
			}

