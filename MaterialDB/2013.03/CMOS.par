		ThinLayerMobility "110":
			{
				beta		= 4.0,		4.0
				zeta		= 0.15,		8.2
				p1		= 0.4,		0.1
				p2		= 50.0,		2.0e6
				p3		= 7.0,		4.0
				mz1		= 0.315,	1.8
