				 }

	    LatticeParameters
		  {
				##project dependent settings
				##definition of relation between principle crystal axis and device coordinate system
				#X			=	(1 1 0)
				#Y			=	(1 -1 0)

					S[1][1]			=	0.77
					S[1][2]			=	-0.21
					S[4][4]			=	1.25

					xis			=	7.044
					dbs			=	0.532
					xiu			=	9.295
					xid			=	1.082
					adp			=	2.46
					bdp			=	-2.35
					ddp			=	-5.32
					dso			=	0.0434

					gamma_1			=	4.31
					gamma_2			=	0.345
					gamma_3			=	1.426667
				}

	MCmob:
                {
				##project dependent settings: explanation of parameters see AdvancedCalibration Device User's Guide
				#autoorientation	=	 1
				#ConstantStress	       =	0
				#Stress_xx	       =	0.0
				#Stress_yy	       =	0.0
				#Stress_zz	       =	0.0
				#ConstantMoleFraction  =	1
				#MoleFraction	       =	0.0
				#channelori	       =	0
				#waferori	       =	0
				#corrections	       =	1

				#cross corrections for Monte Carlo derived for mole fraction of 25%
				#cross corrections extracted and validated between -2.5GPa and 0 for biaxial in-plane stress
				#cross corrections extracted and validated for mole fractions of 0 and 25%
				#cross corrections not extracted and validated for normal stress compenents
				as100c1102h	       =	-0.53
				as100c11018h	       =	0.02
				as100c1002h	       =	0.0
				as100c10018h	       =	-0.04

				##sband parameters for <110>/(001) for silicon
				##uniaxial parameters extracted between: channel: -6GPa and 1GPa
				##uniaxial parameters extracted between: width: -2GPa and 6GPa
				##uniaxial parameters extracted between: normal: -6GPa and 3GPa
				##uniaxial parameters validated between: channel: -6GPa and 3GPa
				##uniaxial parameters validated between: width: -2GPa and 6GPa
				##uniaxial parameters validated between: normal: -6GPa and 1GPa
				#acsi0ges100c1106h     =	-1.04
				#acsi0ges100c1105h     =	0.7882
				#acsi0ges100c1104h     =	0.0496
				#acsi0ges100c1103h     =	-0.10877
				#acsi0ges100c1102h     =	-0.027334
				#acsi0ges100c1101h     =	-0.001904
				#awsi0ges100c1106h     =	0.43537
				#awsi0ges100c1105h     =	0.056169
				#awsi0ges100c1104h     =	-0.039034
				#awsi0ges100c1103h     =	-0.0021034
				#awsi0ges100c1102h     =	0.002595
				#awsi0ges100c1101h     =	-0.00021204
				#ansi0ges100c1106h     =	0.28549
				#ansi0ges100c1105h     =	0.17397
				#ansi0ges100c1104h     =	-0.0145
				#ansi0ges100c1103h     =	-0.00898
				#ansi0ges100c1102h     =	-0.000302
				#ansi0ges100c1101h     =	0.0000648
				##sband parameters for <110>/(001) for SiGe, mole fraction from 0 to 100%
				##uniaxial parameters extracted between: channel: -6GPa and 1GPa
				##uniaxial parameters extracted between: width: -2GPa and 6GPa
				##uniaxial parameters extracted between: normal: -6GPa and 3GPa
				##uniaxial parameters validated between: channel: -6GPa and 3GPa
				##uniaxial parameters validated between: width: -2GPa and 6GPa
				##uniaxial parameters validated between: normal: -6GPa and 1GPa
				#acsi1ges100c1106h     =	0.51977
