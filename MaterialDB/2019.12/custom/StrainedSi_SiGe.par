        B(beta(2))      = 0.0000e+00    # [K]   
        C(beta(2))      = 0.0000e+00    # [K]   
        Xmax(3) = 0.3   # [1]   
        beta(3) = 0.0000e+00    # [K]   
        B(beta(3))      = 0.0000e+00    # [K]   
        C(beta(3))      = 0.0000e+00    # [K]   
        Xmax(4) = 0.4   # [1]   
        beta(4) = 0.0000e+00    # [K]   
        B(beta(4))      = 0.0000e+00    # [K]   
