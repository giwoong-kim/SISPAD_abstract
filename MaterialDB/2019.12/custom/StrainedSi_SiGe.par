       B(mumax(2))     = 0. , 0. 
       C(mumax(2))     = 0. , 0. 
       Xmax(3)        = 0.3, 0.3     # [1]   
       mumax(3)        = 2283., 1747.     # [cm2/(Vs)]
       B(mumax(3))     = 0. , 0. 
       C(mumax(3))     = 0. , 0. 
       Xmax(4)        = 0.4, 0.4     # [1]   
       mumax(4)        = 2285., 2411.     # [cm2/(Vs)]
       B(mumax(4))     = 0. , 0. 
       C(mumax(4))     = 0. , 0. 
       Xmax(5)        = 1.0, 1.0     # [1]   
       mumax(5)        = 2285., 2411.     # [cm2/(Vs)]
       B(mumax(5))     = 0. , 0. 
       C(mumax(5))     = 0. , 0. 

       * parameter Exponent:
       Exponent     = 1.0 , 1.0
       Xmax(0) = 0., 0.
       Xmax(1)        = 0.1, 0.1     # [1]   
       Exponent(1)     = 1.0 , 1.0
       B(Exponent(1))     = 0. , 0. 
       C(Exponent(1))     = 0. , 0. 
       Xmax(2)        = 0.2, 0.2     # [1]   
       Exponent(2)     = 1.0 , 1.0
       B(Exponent(2))     = 0. , 0. 
       C(Exponent(2))     = 0. , 0. 
       Xmax(3)        = 0.3, 0.3     # [1]   
