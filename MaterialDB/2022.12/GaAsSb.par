ConstantMobility:
{ * mu_const = mumax (T/T0)^(-Exponent)
	Xmax(0)	= 0	# [1]
	Xmax(1)	= 1	# [1]

  *	mumax(1)	= 2.8000e+03 ,	4.0000e+02	# [cm^2/(Vs)]
  *	Exponent(1)	= 1 ,	2.1	# [1]

	mumax(0)	= 9.4000e+03 ,	491.5	# [cm^2/(Vs)] # [00Sot]
	Exponent(0)	= 2.1  ,  2.2   # [1] # [00Sot]
  	mumax(1)	= 3.0000e+03 ,	1.0000e+03	# [cm^2/(Vs)] # [Ioffe]
  	Exponent(1)	= 1.50 ,	1.50	# [1] # [04Pal]
}

