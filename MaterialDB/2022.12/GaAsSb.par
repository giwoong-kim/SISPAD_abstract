	Xmax (8) = 0.8
	Xmax (9) = 0.9
	Xmax (10) = 1.0

	Nc300(0) = 4.3519e+17		#[cm-3]
	Nc300(1) = 4.0820e+17		#[cm-3]	
	Nc300(2) = 3.8179e+17		#[cm-3]	
	Nc300(3) = 3.5597e+17		#[cm-3]	
	Nc300(4) = 3.3077e+17		#[cm-3]	
	Nc300(5) = 3.0618e+17		#[cm-3]		
	Nc300(6) = 2.8224e+17		#[cm-3]		
	Nc300(7) = 2.5896e+17		#[cm-3]	
	Nc300(8) = 2.3636e+17		#[cm-3]			
	Nc300(9) = 2.1445e+17		#[cm-3]	
