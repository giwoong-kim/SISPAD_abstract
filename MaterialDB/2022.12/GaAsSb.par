Epsilon
{ 
  * Ratio of the permittivities of material and vacuum
	Xmax(0)	= 0	# [1]
	Xmax(1)	= 1	# [1]

  *	epsilon(0)	= 12.9	# [1] # [Ioffe]
  *	epsilon(1)	= 15.7	# [1] # [Ioffe]

	epsilon(0)	= 12.9	# [1] # [05Ada]
	epsilon(1)	= 15.5	# [1] # [05Ada]
}

LatticeHeatCapacity
{ 
  * lumped electron-hole-lattice heat capacity

	Xmax(0)	= 0	# [1]
	Xmax(1)	= 1	# [1]
	
  * cv() = cv + cv_b * T + cv_c * T^2 + cv_d * T^3 
  *	cv(0)	= 1.7388 		# [J/(K cm^3)]
  *	cv(1)	= 1.4000 		# [J/(K cm^3)]

	cv(0)	= 1.7388 		# [J/(K cm^3)] # [09Ada] 
	cv(1)	= 1.9314 		# [J/(K cm^3)] # [09Ada]

	cv_b(0)	= 0.0000e+00	# [J/(K^2*cm^3)]
	cv_b(1)	= 0.0000e+00	# [J/(K^2*cm^3)]
	cv_c(0)	= 0.0000e+00	# [J/(K^3*cm^3)]
	cv_c(1)	= 0.0000e+00	# [J/(K^3*cm^3)]
	cv_d(0)	= 0.0000e+00	# [J/(K^4*cm^3)]
	cv_d(1)	= 0.0000e+00	# [J/(K^4*cm^3)]
}

Kappa
{ 
  * Lattice thermal conductivity
  * Formula = 0:
  * kappa() = 1 / ( 1/kappa + 1/kappa_b * T + 1/kappa_c * T^2 )

  * Formula = 1:
  * kappa() = kappa + kappa_b * T + kappa_c * T^2 

  *	Formula = 1
  *	Xmax(0)	= 0	# [1]
  *	Xmax(1)	= 1	# [1]

  *	kappa(0)	= 0.45			# [W/(K cm)]
  *	kappa_b(0)	= 0.0000e+00	# [W/(K^2 cm)]
  *	kappa_c(0)	= 0.0000e+00	# [W/(K^3 cm)]

  *	kappa(1)	= 0.32			# [W/(K cm)]
  *	kappa_b(1)	= 0.0000e+00	# [W/(K^2 cm)]
  *	kappa_c(1)	= 0.0000e+00	# [W/(K^3 cm)]

   # [Note] No experimental data available for 0<x<1. 
   # Bowing parameter fitted according to [09Adachi]

	Formula = 0

	Xmax(0)	= 0	# [1]
	Xmax(1)	= 1	# [1]

	* parameter 1/kappa:
	1/kappa(0)	= 2.2222	# [(K cm)/W] # [09Adachi]
	1/kappa(1)	= 2.7778	# [(K cm)/W] # [09Adachi]
	B(1/kappa(1))	= -9.5000e+01	# [(K cm)/W] # Fitted value according to [09Adachi]
	C(1/kappa(1))	= 0.0000e+00	# [(K cm)/W]

	* parameter 1/kappa_b:
	1/kappa_b(0)	= 0.0000e+00	# [cm/W]
	1/kappa_b(1)	= 0.0000e+00	# [cm/W]
	B(1/kappa_b(1))	= 0.0000e+00	# [cm/W]
	C(1/kappa_b(1))	= 0.0000e+00	# [cm/W]

	* parameter 1/kappa_c:
	1/kappa_c(0)	= 0.0000e+00	# [cm/(W K)]
	1/kappa_c(1)	= 0.0000e+00	# [cm/(W K)]
	B(1/kappa_c(1))	= 0.0000e+00	# [cm/(W K)]
	C(1/kappa_c(1))	= 0.0000e+00	# [cm/(W K)]
}

Bandgap
{ 
  * Eg = Eg0 + alpha Tpar^2 / (beta + Tpar) - alpha T^2 / (beta + T)
  * Parameter 'Tpar' specifies the value of lattice 
  * temperature, at which parameters below are defined
  * Chi0 is electron affinity.

  *	Xmax(0)	= 0	# [1]
  *	Xmax(1)	= 1	# [1]

  *	Tpar	= 300	# [K]

	* parameter Eg0:
  *	Eg0(0)	= 1.4225	# [eV]
  *	Eg0(1)	= 0.7260	# [eV]
  *	B(Eg0(1)) = 1.43	# [eV]

	* parameter Chi0:
  *	Chi0(0)	= 4.1665	# [eV]
  *	Chi0(1)	= 4.0700	# [eV]
  *	B(Chi0(1)) = -0.37	# [eV]


   	* parameter Eg0:
	Tpar	= 0.0000e+00	# [K]
	Xmax(0)	= 0.0000e+00	# [1]
	Eg0(0)	= 1.519	# [eV] # [01Vur] 
	Xmax(1)	= 1		# [1]
	Eg0(1)	= 0.812	# [eV] # [01Vur] 
	B(Eg0(1))	= 1.43	# [eV] # [01Vur] 
	C(Eg0(1))	= 0.0000e+00	# [eV]

	* parameter alpha:
	Xmax(0)	= 0.0000e+00	# [1]	
	alpha(0)	= 5.4050e-04	# [eV/K] # [01Vur] 
	Xmax(1)	= 1			# [1]
	alpha(1)	= 4.1700e-04	# [eV/K] # [01Vur] 
	B(alpha(1))	= 0.0000e+00	# [eV/K]
	C(alpha(1))	= 0.0000e+00	# [eV/K]

	* parameter beta:
	Xmax(0)	= 0.0000e+00	# [1]
	beta(0)	= 2.0400e+02	# [K] # [01Vur] 
	Xmax(1)	= 1			# [1]
	beta(1)	= 1.4000e+02	# [K] # [01Vur] 
	B(beta(1))	= 0.0000e+00	# [K]
	C(beta(1))	= 0.0000e+00	# [K]

	* parameter Chi0:
	Xmax(0)	= 0.0000e+00	# [1]
 	Chi0(0)	= 4.1017		# [eV] # [05Ada]
	Xmax(1)	= 1			# [1]
	Chi0(1)	= 4.1674		# [eV] # [05Ada]
	B(Chi0(1))	= 0.0000e+00	# [eV]
	C(Chi0(1))	= 0.0000e+00	# [eV]

	* parameter EgMin:
	Xmax(0)	= 0.0000e+00	# [1]
	EgMin(0)	= 1.5000e-01	# [eV]
	Xmax(1)	= 1	# [1]
	EgMin(1)	= 1.5000e-01	# [eV]
	B(EgMin(1))	= 0.0000e+00	# [eV]
	C(EgMin(1))	= 0.0000e+00	# [eV]
}

eDOSMass
{
  * For effective mass specification Formula1 (me approximation):
  * or Formula2 (Nc300) can be used :
	Formula	= 2	# [1]
  * Formula2:
  * me/m0 = (Nc300/2.5094e19)^2/3 
  * Nc(T) = Nc300 * (T/300)^3/2 
  *	Xmax(0)	= 0	# [1]
  *	Xmax(1)	= 1	# [1]
  *	Nc300(0)	= 4.3519e+17	# [cm-3]
  *	Nc300(1)	= 2.07800e+17	# [cm-3]

  # Reference from [09Ada] with linear interpolation
	Xmax (0) = 0.0
	Xmax (1) = 0.1
	Xmax (2) = 0.2 
	Xmax (3) = 0.3
	Xmax (4) = 0.4
	Xmax (5) = 0.5
	Xmax (6) = 0.6
