	vsat0(0)	= 1.0700e+07,	8.3700e+06	#[cm/s]
	vsat0(1)	= 7.4300e+06,	7.4300e+06	#[cm/s]
	vsatexp(0)	= 0.87,	0.52	#[1]
	vsatexp(1)	= 0.87,	0.52	#[1]
	A_vsat(0)	= 1.0700e+07,	1.0700e+07	#[cm/s]
